{
  "name": "my-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://cmarkgonzales.github.io/my-portfolio/",
  "scripts": {
    "dev": "vite",
    "build": "npm run sync:draco && vite build",
    "preview": "vite preview",
    "optimize:hero": "bash scripts/optimize-hero.sh",
    "sync:draco": "mkdir -p public/assets/draco/gltf && cp node_modules/three/examples/jsm/libs/draco/gltf/draco_wasm_wrapper.js node_modules/three/examples/jsm/libs/draco/gltf/draco_decoder.wasm public/assets/draco/gltf/ && rm -f public/assets/draco/gltf/draco_encoder.js public/assets/draco/gltf/draco_decoder.js",
    "postinstall": "npm run sync:draco",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "@tailwindcss/vite": "^4.1.8",
    "@vitejs/plugin-vue": "^5.2.4",
    "firebase": "^11.9.1",
    "three": "^0.184.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.1.8",
    "vite": "^6.1.0"
  },
  "volta": {
    "node": "20.18.3"
  }
}
